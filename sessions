# ─── main ────────────────────────────────────

def main():
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    args = sys.argv[1:]
    if not args:
        last = DATA_DIR / "last-active.txt"
        print(last.read_text() if last.exists() else "还没有快照（session-tracker 每 5 分钟生成）")
        return
    if args[0] in ("-h", "--help"):
        print(__doc__)
        return
    if args[0] == "_serve":
        serve()
        return
    n = 20
    if "-n" in args:
        i = args.index("-n")
        n = int(args[i + 1])
        del args[i:i + 2]
    cmd, rest = args[0], args[1:]
    if cmd == "list":
        cmd_list(n, rest[0] if rest else None)
    elif cmd == "find" and rest:
        cmd_find(" ".join(rest), n)
    elif cmd == "star" and rest:
        cmd_star(rest[0], " ".join(rest[1:]))
    elif cmd == "unstar" and rest:
        cmd_unstar(rest[0])
    elif cmd == "stars":
        cmd_stars()
    elif cmd == "dash":
        cmd_dash(rest)
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
