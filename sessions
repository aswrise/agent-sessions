#!/usr/bin/env python3
"""Claude Code / Codex 会话工具箱。

用法:
  sessions                         活跃会话快照（读 last-active.txt）
  sessions list [-n 20] [claude|codex]   最近 session（跨全路径）
  sessions find <关键词> [-n 20]         全文搜索（rg 扫全部历史）
  sessions star <id前缀> [备注...]        标记重要
  sessions unstar <id前缀>               取消标记
  sessions stars                         列出已标记
  sessions dash [--no-open]              打开 dashboard（localhost 常驻服务，页内可点★、改备注/名称、归档）
  sessions dash --stop                   停止 dashboard 服务
"""
import json
import re
import sqlite3
import subprocess
import sys
import threading
import time
from datetime import datetime
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from pathlib import Path
from urllib.parse import parse_qs, urlparse

CLAUDE_DIR = Path.home() / ".claude" / "projects"
CODEX_DIR = Path.home() / ".codex" / "sessions"
CODEX_INDEX_FILE = Path.home() / ".codex" / "session_index.jsonl"
CODEX_STATE_FILE = Path.home() / ".codex" / "state_5.sqlite"
PI_DIR = Path.home() / ".pi" / "agent" / "sessions"
DATA_DIR = Path.home() / ".local" / "share" / "session-snapshots"
STARS_FILE = DATA_DIR / "stars.json"
MIN_SIZE = 2048
MAX_HEAD_LINES = 400
DASH_PORT = 7867
INDEX_TTL = 30


# ─── 元数据收集 ───────────────────────────────

def load_claude_names():
    """会话名称：jsonl 里的 custom-title（/rename 手动命名）优先，其次 ai-title（自动生成）"""
    ai, custom = {}, {}
    try:
        out = subprocess.run(
            ["rg", "-N", "--no-messages", "--no-ignore", "--hidden",
             '"type":"(ai|custom)-title"', str(CLAUDE_DIR)],
            capture_output=True, text=True, timeout=60,
        ).stdout
        for line in out.splitlines():
            try:
                rec = json.loads(line.split(":", 1)[1])
            except (json.JSONDecodeError, IndexError):
                continue
            sid = rec.get("sessionId")
            if not sid:
                continue
            # 同一文件多条记录，rg 按文件内顺序输出，后写的覆盖先写的
            if rec.get("type") == "custom-title" and rec.get("customTitle"):
                custom[sid] = rec["customTitle"]
            elif rec.get("aiTitle"):
                ai[sid] = rec["aiTitle"]
    except FileNotFoundError:
        pass
    # 旧版 sessions-index.json 里的 customTitle（历史遗留，仅补充）
    for idx in CLAUDE_DIR.glob("*/sessions-index.json"):
        try:
            for e in json.loads(idx.read_text()).get("entries", []):
                if e.get("customTitle"):
                    custom.setdefault(e["sessionId"], e["customTitle"])
        except Exception:
            pass
    ai.update(custom)
    return ai


def load_codex_names():
    """显式 thread_name 优先，其次使用不同于首条消息的 Codex title。"""
    names = {}
    try:
        with open(CODEX_INDEX_FILE, errors="replace") as fh:
            for line in fh:
                try:
                    rec = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if rec.get("id"):
                    if rec.get("thread_name"):
                        names[rec["id"]] = rec["thread_name"]
                    else:
                        names.pop(rec["id"], None)
    except OSError:
        pass
    try:
        with sqlite3.connect(f"file:{CODEX_STATE_FILE}?mode=ro", uri=True) as db:
            for sid, title, first_msg in db.execute(
                    "SELECT id, title, first_user_message FROM threads"):
                if sid not in names and title and title != first_msg:
                    names[sid] = title
    except sqlite3.Error:
        pass
    return names


def iso2epoch(ts):
    try:
        return datetime.fromisoformat(ts.replace("Z", "+00:00")).timestamp()
    except (ValueError, AttributeError):
        return None


def parse_claude(path):
    sid, cwd, first_msg, birth = path.stem, None, None, None
    try:
        with open(path, errors="replace") as fh:
            for i, line in enumerate(fh):
                if i >= MAX_HEAD_LINES or (cwd and first_msg):
                    break
                try:
                    rec = json.loads(line)
                except json.JSONDecodeError:
                    continue
                cwd = cwd or rec.get("cwd")
                birth = birth or iso2epoch(rec.get("timestamp"))
                if first_msg is None and rec.get("type") == "user" and not rec.get("isSidechain"):
                    content = (rec.get("message") or {}).get("content")
                    if isinstance(content, list):
                        content = " ".join(c.get("text", "") for c in content
                                           if isinstance(c, dict) and c.get("type") == "text")
                    if isinstance(content, str):
                        text = content.strip()
                        if text and not text.startswith(("<", "Caveat:")):
                            first_msg = text
    except OSError:
        return None
    if not cwd:
        return None
    return sid, cwd, first_msg or "", birth


def parse_codex(path):
    try:
        with open(path, errors="replace") as fh:
            meta = json.loads(fh.readline())
            if not isinstance(meta, dict) or not isinstance(meta.get("payload"), dict):
                return None
            payload = meta["payload"]
            sid, cwd = payload.get("id"), payload.get("cwd") or "?"
            if not sid:
                return None
            birth = iso2epoch(payload.get("timestamp")) or iso2epoch(meta.get("timestamp"))
            first_msg = None
            for i, line in enumerate(fh):
                if i >= MAX_HEAD_LINES:
                    break
                if "user" not in line:
                    continue
                try:
                    rec = json.loads(line)
                except json.JSONDecodeError:
                    continue
                p = rec.get("payload", {})
                if p.get("type") == "user_message":
                    text = (p.get("message") or "").strip()
                elif p.get("item", p).get("role") == "user":
                    item = p.get("item", p)
                    text = " ".join(c.get("text", "") for c in (item.get("content") or [])
                                    if isinstance(c, dict) and c.get("type") == "input_text").strip()
                else:
                    continue
                if text and not text.startswith(("<", "#", "⚠")):
                    first_msg = text
                    break
            return sid, cwd, first_msg or "", birth
    except (OSError, json.JSONDecodeError):
        return None


def parse_pi(path):
    """首行 {"type":"session","id","cwd","timestamp"[,"name"]}，消息为 type=message"""
    try:
        with open(path, errors="replace") as fh:
            meta = json.loads(fh.readline())
            if meta.get("type") != "session" or not meta.get("id"):
                return None
            sid, cwd = meta["id"], meta.get("cwd") or "?"
            birth = iso2epoch(meta.get("timestamp"))
            name = meta.get("name") or ""
            first_msg = None
            for i, line in enumerate(fh):
                if i >= MAX_HEAD_LINES:
                    break
                if '"role":"user"' not in line:
                    continue
                try:
                    rec = json.loads(line)
                except json.JSONDecodeError:
                    continue
                msg = rec.get("message", {})
                if rec.get("type") == "message" and msg.get("role") == "user":
                    text = " ".join(c.get("text", "") for c in (msg.get("content") or [])
                                    if isinstance(c, dict) and c.get("type") == "text").strip()
                    if text and not text.startswith("<"):
                        first_msg = text
                        break
            return sid, cwd, first_msg or "", birth, name
    except (OSError, json.JSONDecodeError):
        return None


PARSERS = {"claude": parse_claude, "codex": parse_codex, "pi": parse_pi}


def is_codex_subagent(path):
    """子 agent rollout 只需读首条 session_meta 即可识别。"""
    try:
        with open(path, errors="replace") as fh:
            meta = json.loads(fh.readline())
        payload = meta.get("payload") if isinstance(meta, dict) else None
        return isinstance(payload, dict) and payload.get("thread_source") == "subagent"
    except (OSError, json.JSONDecodeError):
        return False


def iter_files(only=None):
    if only in (None, "claude"):
        for f in CLAUDE_DIR.glob("*/*.jsonl"):
            if not f.name.startswith("agent-"):
                yield "claude", f
    if only in (None, "codex"):
        for f in CODEX_DIR.glob("*/*/*/rollout-*.jsonl"):
            if not is_codex_subagent(f):
                yield "codex", f
    if only in (None, "pi"):
        for f in PI_DIR.glob("*/*.jsonl"):
            yield "pi", f


def one_line(text, limit=100):
    text = re.sub(r"\s+", " ", text or "")
    return text[:limit] + ("…" if len(text) > limit else "")


def tail_model(path, tool):
    """会话当前模型 = 尾部最后一条模型记录（中途可换模型，取最后）。
    模型记录距文件尾的距离不定（codex 的 turn_context 每轮一条，一轮可能几百KB），
    窗口从 64KB 渐进扩到 4MB，仍找不到视为无模型。
    用户消息里贴的 JSON 会被转义成 \\"model\\"，不会误匹配裸的 "model": 键。"""
    def extract(text):
        if tool == "pi":
            pairs = re.findall(r'"provider":"([^"]+)","modelId":"([^"]+)"', text)
            if pairs:
                return "/".join(pairs[-1])
            ids = re.findall(r'"modelId":"([^"]+)"', text)
            return ids[-1] if ids else ""
        models = [m for m in re.findall(r'"model":"([^"]+)"', text)
                  if not m.startswith("<")]  # 排除 "<synthetic>"（API 错误占位）
        return models[-1] if models else ""

    try:
        size = path.stat().st_size
        for win in (65536, 1048576, 4194304):
            with open(path, "rb") as fh:
                fh.seek(max(0, size - win))
                found = extract(fh.read().decode("utf-8", errors="replace"))
            if found or win >= size:
                return found
    except OSError:
        pass
    return ""


_file_cache = {}


def cached_file_metadata(tool, path, stat):
    """解析发生变化的 session 文件；名称和标记由 build_index 每次重新合并。"""
    key = tool, path
    signature = stat.st_mtime_ns, stat.st_size
    cached = _file_cache.get(key)
    if cached and cached[0] == signature:
        return cached[1]
    parsed = PARSERS[tool](path)
    metadata = None
    if parsed:
        metadata = {
            "id": parsed[0], "cwd": parsed[1],
            "first_msg": one_line(parsed[2], 240), "birth": parsed[3],
            "upstream_name": parsed[4] if len(parsed) > 4 else "",
            "model": tail_model(path, tool),
        }
    _file_cache[key] = signature, metadata
    return metadata


def build_index(only=None, limit=None):
    """扫描所有 session，按 mtime 降序，同 id 去重保留最新"""
    names = {"claude": load_claude_names(), "codex": load_codex_names()}
    stars = load_stars()
    files = [(tool, path, path.stat()) for tool, path in iter_files(only)]
    files.sort(key=lambda item: item[2].st_mtime, reverse=True)
    live = {(tool, path) for tool, path, _ in files}
    seen, rows = set(), []
    for tool, f, st in files:
        if st.st_size < MIN_SIZE:
            continue
        metadata = cached_file_metadata(tool, f, st)
        if not metadata:
            continue
        sid = metadata["id"]
        if sid in seen:
            continue
        seen.add(sid)
        star = stars.get(sid)
        upstream_name = (metadata["upstream_name"]
                         or names.get(tool, {}).get(sid, ""))
        name = (star or {}).get("name") or upstream_name
        rows.append({
            "id": sid, "tool": tool, "cwd": metadata["cwd"],
            "name": one_line(name, 120),
            "first_msg": metadata["first_msg"],
            "mtime": st.st_mtime,
            "birth": metadata["birth"] or st.st_mtime,
            "size_kb": st.st_size // 1024,
            "model": metadata["model"],
            "starred": is_starred(star),
            "star_note": (star or {}).get("note", ""),
            "archived": bool((star or {}).get("archived")),
            "status": (star or {}).get("status", ""),
        })
        if limit and len(rows) >= limit:
            break
    scanned_tools = set(PARSERS) if only is None else {only}
    for key in list(_file_cache):
        if key[0] in scanned_tools and key not in live:
            del _file_cache[key]
    return rows


# ─── star 管理 ────────────────────────────────

def load_stars():
    try:
        return json.loads(STARS_FILE.read_text())
    except Exception:
        return {}


def save_stars(stars):
    STARS_FILE.write_text(json.dumps(stars, ensure_ascii=False, indent=1))


def update_mark(sid, star=None, note=None, name=None, archive=None, status=None):
    """星标/备注/名称override/归档/状态 各自独立更新（传 None 的不动），全空则删条目。
    旧格式条目没有 starred 字段，视为已标记。"""
    marks = load_stars()
    e = marks.get(sid) or {"starred": False, "note": ""}
    e.setdefault("starred", True)
    if star is not None:
        e["starred"] = bool(star)
    if note is not None:
        e["note"] = note
    if name is not None:
        e["name"] = name
    if archive is not None:
        e["archived"] = bool(archive)
    if status is not None:
        e["status"] = status
    if (e["starred"] or e.get("note") or e.get("name")
            or e.get("archived") or e.get("status")):
        e.setdefault("added", datetime.now().strftime("%Y-%m-%d %H:%M"))
        marks[sid] = e
    else:
        marks.pop(sid, None)
    save_stars(marks)


def is_starred(entry):
    return bool(entry and entry.get("starred", True))


def find_session_file(tool, sid):
    if tool == "claude":
        hits = list(CLAUDE_DIR.glob(f"*/{sid}.jsonl"))
    elif tool == "codex":
        hits = list(CODEX_DIR.glob(f"*/*/*/rollout-*{sid}.jsonl"))
    elif tool == "pi":
        hits = list(PI_DIR.glob(f"*/*{sid}.jsonl"))
    else:
        hits = []
    return max(hits, key=lambda f: f.stat().st_mtime) if hits else None


def content_text(content):
    if isinstance(content, str):
        return content.strip()
    if not isinstance(content, list):
        return ""
    parts = []
    for c in content:
        if not isinstance(c, dict):
            continue
        text = c.get("text") if c.get("type") in ("text", "input_text", "output_text") else None
        if isinstance(text, str):
            parts.append(text)
    return "\n".join(p.strip() for p in parts if p.strip()).strip()


def skip_transcript_text(role, text):
    return role == "user" and text.startswith((
        "# AGENTS.md instructions",
        "<environment_context",
        "<skill>",
        "Base directory for this skill:",
        "⚠",
    ))


def transcript_messages(tool, sid):
    path = find_session_file(tool, sid)
    if not path:
        raise FileNotFoundError(f"找不到 {tool} session 文件: {sid}")
    out = []
    with open(path, errors="replace") as fh:
        for line in fh:
            try:
                rec = json.loads(line)
            except json.JSONDecodeError:
                continue
            msg = None
            if tool == "claude" and rec.get("type") in ("user", "assistant"):
                if rec.get("isSidechain") or rec.get("toolUseResult"):
                    continue
                msg = rec.get("message") or {}
            elif tool == "codex" and rec.get("type") == "response_item":
                payload = rec.get("payload") or {}
                if payload.get("type") == "message":
                    msg = payload
            elif tool == "pi" and rec.get("type") == "message":
                msg = rec.get("message") or {}
            if not msg or msg.get("role") not in ("user", "assistant"):
                continue
            text = content_text(msg.get("content"))
            if text and not skip_transcript_text(msg["role"], text):
                out.append({"role": msg["role"], "text": text,
                            "timestamp": rec.get("timestamp", "")})
    return out


def rename_session(tool, sid, name):
    """claude: 追加 custom-title 记录（与 /rename 同机制，claude 本体可见）；
    pi: 改首行 meta.name（pi 本体可见）；codex: 只存本工具 override，不写内部索引"""
    if tool == "codex":
        update_mark(sid, name=name)
        return
    if tool not in ("claude", "pi"):
        raise ValueError(f"未知工具: {tool}")
    f = find_session_file(tool, sid)
    if not f:
        raise FileNotFoundError(f"找不到 {tool} session 文件: {sid}")
    if tool == "claude":
        with open(f, "a") as fh:
            fh.write(json.dumps({"type": "custom-title", "customTitle": name,
                                 "sessionId": sid}, ensure_ascii=False) + "\n")
    else:
        # ponytail: 整文件重写首行，正在运行的 pi 同时追加会有极小竞态窗口，本地工具可接受
        head, sep, rest = f.read_text(errors="replace").partition("\n")
        meta = json.loads(head)
        meta["name"] = name
        f.write_text(json.dumps(meta, ensure_ascii=False) + sep + rest)


def resolve_id(prefix):
    matches = set()
    for tool, f in iter_files():
        if tool == "claude":
            sid = f.stem
        else:  # codex/pi 的 uuid 在文件名末尾
            m = re.search(r"([0-9a-f]{8}-[0-9a-f-]{27})\.jsonl$", f.name)
            sid = m.group(1) if m else None
        if sid and sid.startswith(prefix):
            matches.add(sid)
    if len(matches) == 1:
        return matches.pop()
    sys.exit(f"id 前缀 '{prefix}' 匹配到 {len(matches)} 个 session，需要更长前缀" if matches
             else f"没有 session 匹配 '{prefix}'")


def cmd_star(prefix, note):
    sid = resolve_id(prefix)
    update_mark(sid, star=True, note=note or None)
    print(f"★ {sid}" + (f"  ({note})" if note else ""))


def cmd_unstar(prefix):
    stars = load_stars()
    hit = [s for s, v in stars.items() if s.startswith(prefix) and is_starred(v)]
    if len(hit) != 1:
        sys.exit(f"'{prefix}' 匹配到 {len(hit)} 个已标记 session")
    update_mark(hit[0], star=False)
    print(f"已取消 {hit[0]}")


def cmd_stars():
    stars = {s: v for s, v in load_stars().items() if is_starred(v)}
    if not stars:
        print("还没有标记任何 session（sessions star <id前缀> [备注]）")
        return
    for sid, info in sorted(stars.items(), key=lambda kv: kv[1].get("added", ""), reverse=True):
        print(f"★ {sid}  [{info.get('added','')}]  {info.get('note','')}")


# ─── list / find ─────────────────────────────

def resume_cmd(tool, sid, cwd, model=""):
    if tool == "codex":
        return f"cd {cwd} && codex resume {sid}" + (f" -m {model}" if model else "")
    if tool == "pi":
        return f"cd {cwd} && pi --session {sid}" + (f" --model {model}" if model else "")
    return f"cd {cwd} && claude -r {sid}" + (f" --model {model}" if model else "")


def print_entry(r, snippet=None):
    day = datetime.fromtimestamp(r["mtime"]).strftime("%m-%d %H:%M")
    star = "★" if r["starred"] else " "
    print(f"{star} [{day}] {r['tool']:6} {r['cwd']}")
    label = r.get("name") or r["first_msg"]
    print(f"    {one_line(snippet if snippet is not None else label)}")
    print(f"    ↳ {resume_cmd(r['tool'], r['id'], r['cwd'], r.get('model', ''))}\n")


def cmd_list(n, only=None):
    shown = 0
    for r in build_index(only):
        if r["archived"]:
            continue
        print_entry(r)
        shown += 1
        if shown >= n:
            break


def cmd_find(keyword, n):
    try:
        out = subprocess.run(["rg", "-l", "--no-messages", "--no-ignore", "--hidden",
                              keyword, str(CLAUDE_DIR), str(CODEX_DIR), str(PI_DIR)],
                             capture_output=True, text=True, timeout=120).stdout.splitlines()
    except FileNotFoundError:
        sys.exit("需要 ripgrep (rg)")
    hit_files = {Path(p) for p in out
                 if Path(p).suffix == ".jsonl" and not Path(p).name.startswith("agent-")}
    if not hit_files:
        print("没有匹配的 session")
        return
    stars = load_stars()
    shown = 0
    print(f"共 {len(hit_files)} 个匹配 session，显示最近 {min(n, len(hit_files))} 个：\n")
    for f in sorted(hit_files, key=lambda p: p.stat().st_mtime, reverse=True)[:n]:
        s = str(f)
        tool = ("claude" if s.startswith(str(CLAUDE_DIR))
                else "pi" if s.startswith(str(PI_DIR)) else "codex")
        parsed = PARSERS[tool](f)
        if not parsed:
            continue
        sid, cwd = parsed[0], parsed[1]
        m = subprocess.run(["rg", "-m1", "-o", "--no-ignore", "--hidden",
                            f".{{0,40}}{re.escape(keyword)}.{{0,60}}", str(f)],
                           capture_output=True, text=True).stdout.strip().splitlines()
        print_entry({"id": sid, "tool": tool, "cwd": cwd, "name": "", "first_msg": "",
                     "model": tail_model(f, tool),
                     "mtime": f.stat().st_mtime, "starred": is_starred(stars.get(sid))},
                    m[0] if m else keyword)
        shown += 1


# ─── dashboard 服务 ──────────────────────────

_cache = {"rows": None, "at": 0.0}
_cache_lock = threading.Lock()


def cached_index(force=False):
    with _cache_lock:
        if force or _cache["rows"] is None or time.time() - _cache["at"] > INDEX_TTL:
            _cache["rows"] = build_index()
            _cache["at"] = time.time()
        return _cache["rows"], _cache["at"]


class DashHandler(BaseHTTPRequestHandler):
    def log_message(self, *a):
        pass

    def _send(self, code, body, ctype="text/html; charset=utf-8"):
        data = body.encode()
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        url = urlparse(self.path)
        if url.path in ("/", "/index.html"):
            rows, built_at = cached_index(force="fresh" in url.query)
            now = datetime.fromtimestamp(built_at).strftime("%Y-%m-%d %H:%M:%S")
            page = (DASH_TEMPLATE
                    .replace("__DATA__", json.dumps(rows, ensure_ascii=False).replace("</", "<\\/"))
                    .replace("__HOME__", str(Path.home()))
                    .replace("__NOW__", now).replace("__COUNT__", str(len(rows))))
            self._send(200, page)
        elif url.path == "/api/session":
            sid = (parse_qs(url.query).get("id") or [""])[0]
            rows, _ = cached_index()
            row = next((r for r in rows if r["id"] == sid), None)
            if not row:
                self._send(404, '{"error":"session not found"}', "application/json")
                return
            try:
                detail = dict(row, messages=transcript_messages(row["tool"], sid))
            except Exception as e:
                self._send(500, json.dumps({"error": str(e)}, ensure_ascii=False),
                           "application/json")
                return
            self._send(200, json.dumps(detail, ensure_ascii=False), "application/json")
        else:
            self._send(404, "not found", "text/plain")

    def do_POST(self):
        try:
            body = json.loads(self.rfile.read(int(self.headers.get("Content-Length", 0))))
            sid = body["id"]
        except Exception:
            self._send(400, '{"error":"bad request"}', "application/json")
            return
        if self.path == "/star":
            update_mark(sid, star=body.get("star"), note=body.get("note"),
                        archive=body.get("archive"), status=body.get("status"))
            with _cache_lock:
                for r in _cache["rows"] or []:
                    if r["id"] == sid:
                        if body.get("star") is not None:
                            r["starred"] = bool(body["star"])
                        if body.get("note") is not None:
                            r["star_note"] = body["note"]
                        if body.get("archive") is not None:
                            r["archived"] = bool(body["archive"])
                        if body.get("status") is not None:
                            r["status"] = body["status"]
        elif self.path == "/rename":
            name = (body.get("name") or "").strip()
            if not name:
                self._send(400, '{"error":"empty name"}', "application/json")
                return
            try:
                rename_session(body.get("tool"), sid, name)
            except Exception as e:
                self._send(500, json.dumps({"error": str(e)}, ensure_ascii=False),
                           "application/json")
                return
            with _cache_lock:
                for r in _cache["rows"] or []:
                    if r["id"] == sid:
                        r["name"] = name
        else:
            self._send(404, "not found", "text/plain")
            return
        self._send(200, '{"ok":true}', "application/json")


def serve():
    ThreadingHTTPServer(("127.0.0.1", DASH_PORT), DashHandler).serve_forever()


def open_url(url):
    import shutil
    if sys.platform == "darwin":
        cmds = [["open", url]]
    elif shutil.which("explorer.exe"):  # WSL
        cmds = [["explorer.exe", url]]
    else:
        cmds = [["xdg-open", url]]
    for cmd in cmds:
        try:
            subprocess.Popen(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return
        except OSError:
            continue
    print("请手动在浏览器打开上面的地址")


def server_alive():
    import socket
    try:
        with socket.create_connection(("127.0.0.1", DASH_PORT), timeout=0.5):
            return True
    except OSError:
        return False


def cmd_dash(rest):
    if "--stop" in rest:
        subprocess.run(["pkill", "-f", "sessions _serve"])
        print("dashboard 服务已停止")
        return
    if not server_alive():
        subprocess.Popen([sys.executable, str(Path(__file__).resolve()), "_serve"],
                         start_new_session=True,
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        for _ in range(40):
            if server_alive():
                break
            time.sleep(0.1)
    url = f"http://localhost:{DASH_PORT}/"
    print(f"dashboard: {url}（sessions dash --stop 停止服务）")
    if "--no-open" not in rest:
        open_url(url)


