<button class="f act" id="reload" title="重新扫描 session 数据">刷新</button>
<button class="f act" id="theme" title="切换深浅主题" aria-label="切换深浅主题">◐</button>
</div>
<div class="bar2" id="advancedFilters" hidden>
<label>更新</label><input type="date" id="uf"> - <input type="date" id="ut">
<label>创建</label><input type="date" id="cf"> - <input type="date" id="ct">
<label>大小(MB)</label><input type="number" id="smin" min="0" step="0.1" placeholder="最小">
 - <input type="number" id="smax" min="0" step="0.1" placeholder="最大">
<label>状态</label><button class="select-button" id="statusFilter" type="button" aria-haspopup="listbox" aria-expanded="false"><span class="select-label">全部状态</span><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="m2 4 4 4 4-4"/></svg></button>
<button class="f" id="clear">清除筛选</button>
</div></div>
<main><section id="list"><table>
<colgroup><col class="c-star"><col class="c-date"><col class="c-date"><col class="c-tool"><col class="c-model">
<col class="c-name"><col class="c-note"><col class="c-stat"><col><col class="c-path"><col class="c-size"><col class="c-detail"><col class="c-archive"></colgroup>
<thead><tr><th data-k="starred" class="action-head">★</th><th data-k="mtime">更新</th><th data-k="birth">创建</th><th data-k="tool">工具</th>
<th data-k="model">模型</th><th data-k="name">名称</th><th data-k="star_note">备注</th><th data-k="status">状态</th><th data-k="first_msg">首条消息</th>
<th data-k="cwd">路径</th><th data-k="size_kb" class="num">大小</th><th title="详情" class="action-head">详情</th><th title="归档" class="action-head">归档</th></tr></thead>
<tbody id="tb"></tbody></table>
<div class="foot" id="foot"></div>
<nav class="pager" id="pager" aria-label="分页" hidden>
<button class="f act" id="prev" type="button" aria-label="上一页">上一页</button>
<span class="p" id="pageInfo" aria-live="polite"></span>
<button class="f act" id="next" type="button" aria-label="下一页">下一页</button>
</nav></section><section id="detail" hidden></section></main>
<div id="menu" class="menu" role="listbox" tabindex="-1"></div><div id="toast"></div><div id="tip"></div>
<script type="application/json" id="raw">__DATA__</script>
<script>
const DATA=JSON.parse(document.getElementById('raw').textContent);
const HOME='__HOME__';
const hay=r=>{r._hay=(r.name+' '+r.star_note+' '+r.first_msg).toLowerCase()};
DATA.forEach((r,i)=>{r._i=i;hay(r);
  r._p=r.cwd.startsWith(HOME)?'~'+r.cwd.slice(HOME.length):r.cwd;});
const PAGE_SIZE=100;
let page=1,tool='',pathSel='',sortK='',sortAsc=false,timer=null;
const q=document.getElementById('q'),tb=document.getElementById('tb'),
      foot=document.getElementById('foot'),toast=document.getElementById('toast'),
      pathButton=document.getElementById('pathButton'),statusFilter=document.getElementById('statusFilter'),
      menuEl=document.getElementById('menu'),list=document.getElementById('list'),
      detail=document.getElementById('detail'),pager=document.getElementById('pager'),
      pageInfo=document.getElementById('pageInfo'),prev=document.getElementById('prev'),
      next=document.getElementById('next'),chromeEl=document.getElementById('chrome'),
      advancedFilters=document.getElementById('advancedFilters'),
      filterToggle=document.getElementById('filterToggle'),filterCount=document.getElementById('filterCount');
let advancedOpen=false,statusFilterValue='';
const pathItems=[{value:'',label:'全部路径'}];
{const cnt={};DATA.forEach(r=>cnt[r.cwd]=(cnt[r.cwd]||0)+1);
 Object.entries(cnt).sort((a,b)=>b[1]-a[1]).forEach(([p,n])=>{
   pathItems.push({value:p,label:`${p.startsWith(HOME)?'~'+p.slice(HOME.length):p} (${n})`});});}
['uf','ut','cf','ct','smin','smax'].forEach(id=>
  document.getElementById(id).addEventListener('input',()=>{page=1;clearTimeout(timer);timer=setTimeout(render,120)}));
document.getElementById('clear').onclick=()=>{
  ['uf','ut','cf','ct','smin','smax'].forEach(id=>document.getElementById(id).value='');
  q.value='';pathSel='';statusFilterValue='';
  setSelectLabel(pathButton,'全部路径');setSelectLabel(statusFilter,'全部状态');
  document.querySelectorAll('button.f[data-t]').forEach(x=>x.classList.remove('on'));
  document.querySelector('button.f[data-t=""]').classList.add('on');
  tool='';page=1;advancedOpen=false;advancedFilters.hidden=true;
  filterToggle.setAttribute('aria-expanded','false');render();};
filterToggle.onclick=()=>{
  advancedOpen=!advancedOpen;advancedFilters.hidden=!advancedOpen;
  filterToggle.setAttribute('aria-expanded',String(advancedOpen));
  filterToggle.classList.toggle('on',advancedOpen||activeFilterCount()>0);
};
const fmt=t=>{const d=new Date(t*1000),z=n=>(n+'').padStart(2,'0');
  return z(d.getMonth()+1)+'-'+z(d.getDate())+' '+z(d.getHours())+':'+z(d.getMinutes())};
const esc=s=>(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const cmd=r=>{const m=r.model;
  if(r.tool==='codex')return`cd ${r.cwd} && codex resume ${r.id}`+(m?` -m ${m}`:'');
  if(r.tool==='pi')return`cd ${r.cwd} && pi --session ${r.id}`+(m?` --model ${m}`:'');
  return`cd ${r.cwd} && claude -r ${r.id}`+(m?` --model ${m}`:'')};
const STATUS=['','todo','in progress','review','blocked','done','archived'];
const STM={
  '': ['无','var(--ash)'],todo:['todo','var(--fog)'],
  'in progress':['progress','#78b8ff'],review:['review','#c6a4ff'],
  blocked:['blocked','#ff8d8d'],done:['done','#6fd49b'],archived:['archived','var(--ash)']};
const STATUS_ITEMS=STATUS.map(s=>({value:s,label:s||'无'}));
const stSel=r=>{const m=STM[r.status]||[r.status,'var(--smoke)'];
  return `<button class="status statusbtn" type="button" aria-haspopup="listbox" aria-expanded="false" style="--sc:${m[1]}"><span class="${r.status?'':'none'}">${esc(m[0])}</span></button>`};
function setSelectLabel(button,label){button.querySelector('.select-label').textContent=label}
let menuAnchor=null,menuItems=[],menuValue='',menuSelect=null,menuWidth=0;
function closeMenu(refocus=false){
  if(!menuAnchor)return;
  const anchor=menuAnchor;anchor.setAttribute('aria-expanded','false');
  menuEl.classList.remove('show');menuAnchor=null;
  if(refocus)anchor.focus();
}
function placeMenu(){
  const r=menuAnchor.getBoundingClientRect(),w=Math.min(Math.max(menuWidth||r.width,150),innerWidth-24);
  menuEl.style.width=w+'px';
  let left=Math.max(12,Math.min(r.left,innerWidth-w-12)),top=r.bottom+6,above=false;
  if(top+menuEl.offsetHeight>innerHeight-12){top=Math.max(12,r.top-menuEl.offsetHeight-6);above=true}
  menuEl.style.left=left+'px';menuEl.style.top=top+'px';
  menuEl.style.transformOrigin=above?'bottom left':'top left';
}
function openMenu(anchor,items,value,onSelect,width=0){
  if(menuAnchor===anchor){closeMenu(true);return}
  closeMenu();menuAnchor=anchor;menuItems=items;menuValue=value;menuSelect=onSelect;menuWidth=width;
  anchor.setAttribute('aria-expanded','true');
  menuEl.innerHTML=items.map((item,i)=>`<button class="menu-option" type="button" role="option" data-index="${i}" aria-selected="${item.value===value}"><span>${esc(item.label)}</span><span class="check">✓</span></button>`).join('');
  menuEl.classList.add('show');placeMenu();
  requestAnimationFrame(()=>{(menuEl.querySelector('[aria-selected=true]')||menuEl.firstElementChild)?.focus()});
}
menuEl.onclick=e=>{
  const option=e.target.closest('.menu-option');if(!option)return;
  const item=menuItems[+option.dataset.index],select=menuSelect;
  closeMenu();select(item.value,item.label);
};
menuEl.onkeydown=e=>{
  const options=[...menuEl.querySelectorAll('.menu-option')],i=options.indexOf(document.activeElement);
  if(e.key==='ArrowDown'||e.key==='ArrowUp'){
    e.preventDefault();options[(i+(e.key==='ArrowDown'?1:-1)+options.length)%options.length].focus();
  }else if(e.key==='Home'){e.preventDefault();options[0]?.focus()}
  else if(e.key==='End'){e.preventDefault();options.at(-1)?.focus()}
  else if(e.key==='Escape'){e.preventDefault();closeMenu(true)}
};
document.addEventListener('click',e=>{
  if(menuAnchor&&!menuEl.contains(e.target)&&!menuAnchor.contains(e.target))closeMenu();
});
pathButton.onclick=()=>openMenu(pathButton,pathItems,pathSel,(value,label)=>{
  pathSel=value;setSelectLabel(pathButton,label);page=1;render();
},320);
statusFilter.onclick=()=>openMenu(statusFilter,
  [{value:'',label:'全部状态'},...STATUS_ITEMS.slice(1)],statusFilterValue,(value,label)=>{
    statusFilterValue=value;setSelectLabel(statusFilter,label);page=1;render();
  });
function pop(msg){toast.textContent=msg;toast.classList.add('show');
  clearTimeout(pop._t);pop._t=setTimeout(()=>toast.classList.remove('show'),1200)}
function activeFilterCount(){
  return ['uf','ut','cf','ct','smin','smax'].filter(id=>document.getElementById(id).value).length+(statusFilterValue?1:0);
}
function syncChrome(){
  const counts={'':DATA.filter(r=>!r.archived).length,
    claude:DATA.filter(r=>!r.archived&&r.tool==='claude').length,
    codex:DATA.filter(r=>!r.archived&&r.tool==='codex').length,
    pi:DATA.filter(r=>!r.archived&&r.tool==='pi').length,
    __star__:DATA.filter(r=>!r.archived&&r.starred).length,
    __arch__:DATA.filter(r=>r.archived).length};
  document.querySelectorAll('.tabs button[data-t]').forEach(b=>b.dataset.count=counts[b.dataset.t]||0);
  const n=activeFilterCount();filterCount.hidden=!n;filterCount.textContent=n;
  filterToggle.classList.toggle('on',advancedOpen||n>0);
}
function render(){
  syncChrome();
  const kw=q.value.trim().toLowerCase();
  let rows=DATA;
  if(tool==='__arch__')rows=rows.filter(r=>r.archived);
  else{rows=rows.filter(r=>!r.archived);
    if(tool==='__star__')rows=rows.filter(r=>r.starred);
    else if(tool)rows=rows.filter(r=>r.tool===tool);}
  if(pathSel)rows=rows.filter(r=>r.cwd===pathSel);
  const from=id=>{const v=document.getElementById(id).value;
    return v?new Date(v+'T00:00:00').getTime()/1000:null};
  const to=id=>{const v=document.getElementById(id).value;
    return v?new Date(v+'T23:59:59').getTime()/1000:null};
  const uf=from('uf'),ut=to('ut'),cf=from('cf'),ct=to('ct'),
        smin=parseFloat(document.getElementById('smin').value),
        smax=parseFloat(document.getElementById('smax').value);
  if(uf)rows=rows.filter(r=>r.mtime>=uf);
  if(ut)rows=rows.filter(r=>r.mtime<=ut);
  if(cf)rows=rows.filter(r=>r.birth>=cf);
  if(ct)rows=rows.filter(r=>r.birth<=ct);
  if(!isNaN(smin))rows=rows.filter(r=>r.size_kb>=smin*1024);
  if(!isNaN(smax))rows=rows.filter(r=>r.size_kb<=smax*1024);
  const sf=statusFilterValue;
  if(sf)rows=rows.filter(r=>r.status===sf);
  if(kw)rows=rows.filter(r=>r._hay.includes(kw));
  if(sortK)rows=[...rows].sort((a,b)=>{const x=a[sortK],y=b[sortK];
    return(x<y?-1:x>y?1:0)*(sortAsc?1:-1)});
  else rows=[...rows].sort((a,b)=>b.mtime-a.mtime);
  const total=rows.length,pages=Math.ceil(total/PAGE_SIZE);
  if(!total){
    tb.innerHTML=`<tr><td colspan="13"><div class="empty">没有匹配的 session，试试更短的关键词或切换筛选</div></td></tr>`;
    foot.textContent='';pager.hidden=true;syncSortMark();return;}
  page=Math.min(page,pages);
  const start=(page-1)*PAGE_SIZE;
  rows=rows.slice(start,start+PAGE_SIZE);
  tb.innerHTML=rows.map(r=>`<tr class="row${r.starred?' starred':''}${r.archived?' archived':''}" data-i="${r._i}">
   <td class="starcell"><button class="rowbtn starbtn" type="button" aria-label="${r.starred?'取消标记':'标记重要'}" title="${r.starred?'取消标记':'标记重要'}">${r.starred?'★':'☆'}</button></td>
   <td class="dt">${fmt(r.mtime)}</td><td class="dt">${fmt(r.birth)}</td><td class="tool"><span class="tool-pill ${r.tool}">${r.tool}</span></td>
   <td class="tool">${esc(r.model)}</td>
   <td class="namecell nm">${esc(r.name)}</td>
   <td class="notecell">${esc(r.star_note)}</td>
   <td>${stSel(r)}</td>
   <td class="msg">${esc(r.first_msg)||'(空)'}</td>
   <td class="p">${esc(r._p)}</td>
   <td class="num sz">${r.size_kb>=1024?(r.size_kb/1024).toFixed(1)+'M':r.size_kb+'K'}</td>
   <td class="detailcell"><button class="rowbtn detailbtn" type="button" title="打开详情页">查看</button></td>
   <td class="archcell"><button class="rowbtn archivebtn" type="button" title="${r.archived?'解除归档':'归档（在"已归档"视图可找回）'}">${r.archived?'恢复':'归档'}</button></td></tr>`).join('');
  pager.hidden=pages<=1;pageInfo.textContent=`第 ${page} / ${pages} 页`;
  prev.disabled=page===1;next.disabled=page===pages;
  foot.textContent=(pages>1?`显示第 ${start+1}-${start+rows.length} 行，共 ${total} 个匹配`:`${total} 个匹配`)
    +'。点击行复制恢复命令，点详情打开详情页，首条消息悬停预览对话';
  syncSortMark();
}
prev.onclick=()=>{if(page>1){page--;render();scrollTo(0,0)}};
next.onclick=()=>{page++;render();scrollTo(0,0)};
function setListMode(on){
  list.hidden=!on;detail.hidden=on;
  chromeEl.hidden=!on;
  if(on)advancedFilters.hidden=!advancedOpen;
}
function showList(push=true){
  setListMode(true);
  if(push)history.pushState(null,'','/');
}
function detailHtml(d){
  const title=esc(d.name||d.first_msg||d.id);
  const meta=`${d.tool} · ${d.model||'无模型'} · ${d._p||d.cwd} · ${d.size_kb>=1024?(d.size_kb/1024).toFixed(1)+'M':d.size_kb+'K'}`;
  const msgs=d.messages.length?d.messages.map(m=>`<article class="bubble ${m.role}">
    <div class="role">${esc(m.role)}</div><div class="body">${esc(m.text)}</div></article>`).join('')
    :'<div class="empty">没有可展示的 user / assistant 文本消息</div>';
  return `<div class="detail-top"><button class="f act" id="back">返回</button>
    <button class="f act" id="copycmd">复制恢复命令</button><div class="detail-title">${title}</div>
    <div class="detail-meta mono">${esc(meta)}</div></div><div class="msglist">${msgs}</div>`;
}
async function openDetail(id,push=true){
  const r=DATA.find(x=>x.id===id);
  setListMode(false);detail.innerHTML='<div class="empty">加载中...</div>';
  if(push)history.pushState(null,'','/?session='+encodeURIComponent(id));
  const resp=await fetch('/api/session?id='+encodeURIComponent(id));
  if(!resp.ok){detail.innerHTML='<div class="empty">加载失败</div>';return}
  const d=await resp.json();d._p=r?r._p:d.cwd;
  detail.innerHTML=detailHtml(d);
  document.getElementById('back').onclick=()=>showList();
  document.getElementById('copycmd').onclick=()=>{navigator.clipboard.writeText(cmd(d));pop('已复制恢复命令')};
}
async function loadDetail(r){
  if(r._detail)return r._detail;
  if(!r._detailPromise)r._detailPromise=fetch('/api/session?id='+encodeURIComponent(r.id))
    .then(resp=>{if(!resp.ok)throw new Error('load failed');return resp.json()})
    .then(d=>{d._p=r._p;r._detail=d;return d});
  return r._detailPromise;
}
const previewHtml=d=>`<div class="tiptitle">${esc(d.name||d.first_msg||d.id)}</div>`
  +(d.messages.length?d.messages.map(m=>`<div class="tipmsg ${m.role}"><div class="tiprole">${esc(m.role)}</div><div class="tiptext">${esc(m.text)}</div></div>`).join('')
    :'<div class="tipmsg">没有可展示的 user / assistant 文本消息</div>');
function syncSortMark(){
  document.querySelectorAll('th[data-k]').forEach(h=>{
    h.classList.toggle('s-asc',h.dataset.k===sortK&&sortAsc);
    h.classList.toggle('s-desc',h.dataset.k===sortK&&!sortAsc);});
}
q.addEventListener('input',()=>{page=1;clearTimeout(timer);timer=setTimeout(render,120)});
// 悬浮预览：首条消息列预览完整对话，其他截断单元格预览完整文本
const tip=document.getElementById('tip');
let tipKey='',tipHideTimer=null,tipShowTimer=null,tipVisible=false,tipAnchor=null,tipHtml='';
function cancelTipHide(){clearTimeout(tipHideTimer)}
function cancelTipShow(){clearTimeout(tipShowTimer);tipShowTimer=null}
function hideTip(){cancelTipHide();cancelTipShow();tipKey='';tipVisible=false;tip.classList.remove('show','instant')}
function scheduleTipHide(){cancelTipHide();tipHideTimer=setTimeout(hideTip,100)}
function placeTip(td){
  const overlap=4,r=td.getBoundingClientRect(),w=Math.min(820,innerWidth-24);
  tip.style.left=Math.max(12,Math.min(r.left,innerWidth-w-12))+'px';
  let top=r.bottom-overlap,above=false;
  if(top+tip.offsetHeight>innerHeight-8){top=Math.max(8,r.top-tip.offsetHeight+overlap);above=true}
  tip.style.transformOrigin=above?'bottom left':'top left';
  tip.style.top=top+'px';
}
function showTip(td,key,html){
  cancelTipHide();tipAnchor=td;tipHtml=html;
  if(key!==tipKey){tipKey=key;cancelTipShow()}
  const reveal=()=>{
    tipShowTimer=null;tip.innerHTML=tipHtml;
    tip.classList.toggle('instant',tipVisible);tip.classList.add('show');
    placeTip(tipAnchor);tipVisible=true;
  };
  if(tipVisible)reveal();else if(!tipShowTimer)tipShowTimer=setTimeout(reveal,180);
}
function updateTip(key,html){
  if(key!==tipKey)return;
  tipHtml=html;
  if(tipVisible){tip.innerHTML=html;placeTip(tipAnchor)}
}
tb.addEventListener('mouseover',async e=>{
  cancelTipHide();
  if(e.target.closest('button,input,select')){hideTip();return}
  const td=e.target.closest('td');
  if(!td){hideTip();return}
  if(td.classList.contains('msg')){
    const r=DATA[+td.closest('tr').dataset.i],key='msg:'+r.id;
    showTip(td,key,'加载对话预览...');
    try{const d=await loadDetail(r);updateTip(key,previewHtml(d))}
    catch(e){updateTip(key,'加载失败')}
    return;
  }
  if(td.scrollWidth<=td.clientWidth+1){hideTip();return}
  const key='text:'+td.closest('tr').dataset.i+':'+td.cellIndex;
  showTip(td,key,esc(td.textContent));});
tb.addEventListener('mouseout',scheduleTipHide);
tip.addEventListener('mouseenter',cancelTipHide);
tip.addEventListener('mouseleave',scheduleTipHide);
addEventListener('scroll',e=>{
  if(e.target!==tip)hideTip();
  if(e.target!==menuEl)closeMenu();
},true);
function editCell(td,r,field){
  if(td.querySelector('input'))return;
  const old=r[field]||'',input=document.createElement('input');
  input.className='cell-input';input.value=old;td.textContent='';td.appendChild(input);input.focus();input.select();
  let done=false;
  const finish=async save=>{
    if(done)return;done=true;
    const value=input.value.trim();
    if(!save||value===old){render();return}
    if(field==='name'&&!value){pop('名称不能为空');render();return}
    const body=field==='name'?{id:r.id,tool:r.tool,name:value}:{id:r.id,note:value};
    const resp=await fetch(field==='name'?'/rename':'/star',{method:'POST',body:JSON.stringify(body)});
    if(!resp.ok){pop(field==='name'?'改名失败':'保存失败');render();return}
    r[field]=value;hay(r);pop(field==='name'&&r.tool==='codex'?'已改名（仅本工具可见）':'已保存');render();
  };
  input.onkeydown=e=>{
    e.stopPropagation();
    if(e.key==='Enter'){e.preventDefault();finish(true)}
    else if(e.key==='Escape'){e.preventDefault();finish(false)}
  };
  input.onblur=()=>finish(true);
}
tb.addEventListener('click',async e=>{
  hideTip();
  if(e.target.classList.contains('cell-input'))return;
  const tr=e.target.closest('tr.row');if(!tr)return;
  const r=DATA[+tr.dataset.i];
  if(e.target.closest('.starbtn')){
    const star=!r.starred;
    const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,star})});
    if(!resp.ok){pop('保存失败');return}
    r.starred=star;pop(star?'已标记':'已取消');render();
    return;}
  const statusButton=e.target.closest('.statusbtn');
  if(statusButton){
    openMenu(statusButton,STATUS_ITEMS,r.status,async status=>{
      const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,status})});
      if(!resp.ok){pop('保存失败');return}
      r.status=status;pop(status?'状态：'+status:'已清除状态');render();
    });
    return;
  }
  if(e.target.closest('.notecell')){editCell(e.target.closest('.notecell'),r,'star_note');return}
  if(e.target.closest('.detailbtn')){
    openDetail(r.id);
    return;}
  if(e.target.closest('.archivebtn')){
    const archive=!r.archived;
    const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,archive})});
    if(!resp.ok){pop('保存失败');return}
    r.archived=archive;pop(archive?'已归档':'已解除归档');render();
    return;}
  if(e.target.closest('.namecell')){editCell(e.target.closest('.namecell'),r,'name');return}
  navigator.clipboard.writeText(cmd(r));pop('已复制恢复命令');});
addEventListener('popstate',()=>{
  const id=new URLSearchParams(location.search).get('session');
  if(id)openDetail(id,false);else showList(false);
});
document.getElementById('reload').onclick=()=>{location.href='/?fresh=1'};
