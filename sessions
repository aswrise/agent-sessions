  background:var(--void);border-bottom:1px solid var(--graphite);z-index:2}
input[type=search]{flex:1;min-width:220px;padding:8px 12px;font:inherit;color:var(--mist);
  border:1px solid var(--input-line);border-radius:6px;background:var(--input-bg);outline:none}
input[type=search]::placeholder{color:var(--ash)}
input[type=search]:focus{border-color:var(--mist)}
.f{padding:4px 12px;font:inherit;font-size:13px;border:none;border-radius:9999px;
  background:none;color:var(--fog);cursor:pointer}
.f:hover{background:var(--chip);color:var(--mist)}
.f.on{background:var(--bone);color:var(--void);font-weight:510}
.f:focus-visible,input[type=search]:focus-visible{outline:2px solid var(--mist);outline-offset:1px}
.act{border:1px solid var(--graphite);border-radius:6px}
.sep{width:1px;height:16px;background:var(--graphite);margin:0 4px}
main{max-width:1280px;margin:0 auto;padding:0 32px 48px}
table{width:100%;border-collapse:collapse;table-layout:fixed}
col.c-star{width:32px}col.c-date{width:92px}col.c-tool{width:60px}
col.c-name{width:230px}col.c-note{width:120px}col.c-path{width:180px}col.c-size{width:70px}
select#path{max-width:240px;padding:4px 8px;font:inherit;font-size:13px;color:var(--fog);
  border:1px solid var(--input-line);border-radius:6px;background:var(--input-bg)}
.bar2{display:flex;gap:6px;align-items:center;flex-wrap:wrap;
  padding:8px 32px;max-width:1280px;margin:0 auto;color:var(--ash);font-size:12px}
.bar2 label{margin-left:8px}
.bar2 input{padding:3px 6px;font:inherit;font-size:12px;color:var(--mist);
  border:1px solid var(--input-line);border-radius:6px;background:var(--input-bg);outline:none}
.bar2 input[type=number]{width:76px}
.bar2 input:focus{border-color:var(--mist)}
th{text-align:left;font-size:12px;font-weight:400;color:var(--ash);position:relative;
  padding:12px 8px 8px;border-bottom:1px solid var(--graphite);cursor:pointer;user-select:none;white-space:nowrap}
th:hover{color:var(--fog)}
th.s-asc::after{content:" ↑";color:var(--mist)}
th.s-desc::after{content:" ↓";color:var(--mist)}
.rs{position:absolute;top:0;right:-3px;width:7px;height:100%;cursor:col-resize;z-index:1}
.rs:hover,.rs.on{border-right:2px solid var(--smoke)}
th.num{text-align:right}
td{padding:8px;border-bottom:1px solid var(--obsidian);vertical-align:baseline;
  overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
td.num{text-align:right}
tr.row{cursor:pointer}
.empty{padding:48px 8px;color:var(--ash);text-align:center}
tr.row:hover td{background:var(--hover)}
tr.row.starred td{background:var(--star-wash)}
.dt,.tool,.sz{font-family:"Berkeley Mono",ui-monospace,"Cascadia Code",Consolas,monospace;
  font-size:12px;color:var(--ash);letter-spacing:-.013em}
td.starcell{cursor:pointer;color:var(--smoke);text-align:center;font-size:14px}
td.starcell:hover{color:var(--lime)}
tr.starred td.starcell{color:var(--lime)}
.nm{font-weight:510;color:var(--paper)}
td.notecell{color:var(--mist);font-size:12px;cursor:text}
td.notecell:empty:hover::after{content:"点击添加备注";color:var(--smoke)}
td.namecell{cursor:text}
td.namecell:empty:hover::after{content:"点击命名";color:var(--smoke);font-weight:400}
td.archcell{cursor:pointer;color:var(--smoke);text-align:center;font-size:13px}
td.archcell:hover{color:var(--mist)}
tr.archived td{opacity:.6}
col.c-stat{width:104px}col.c-model{width:120px}
select.st{border:none;background:none;font:inherit;font-size:12px;padding:0;
  cursor:pointer;outline:none;appearance:none;color:var(--smoke);max-width:100%}
select.st:hover{color:var(--fog)}
.msg{cursor:pointer;color:var(--fog)}
.p{color:var(--ash);font-size:12px;font-family:"Berkeley Mono",ui-monospace,Consolas,monospace;letter-spacing:-.013em}
.foot{color:var(--ash);font-size:12px;padding:16px 8px}
#toast{position:fixed;bottom:24px;left:50%;transform:translate(-50%,8px);opacity:0;
  background:var(--bone);color:var(--void);padding:8px 16px;border-radius:6px;font-size:13px;font-weight:510;
  box-shadow:rgba(8,9,10,.6) 0 4px 32px;pointer-events:none;transition:opacity .15s,transform .15s}
#toast.show{opacity:1;transform:translate(-50%,0)}
</style>
<script>document.documentElement.dataset.theme=
  localStorage.theme||(matchMedia('(prefers-color-scheme: light)').matches?'light':'dark');</script>
</head><body>
<header><h1>Sessions</h1>
<span class="meta">__COUNT__ 个 session，数据时间 __NOW__</span>
</header>
<div class="bar">
<input type="search" id="q" placeholder="过滤：名称 / 首条消息 / 路径 / 备注 / id">
<button class="f on" data-t="">全部</button><button class="f" data-t="claude">claude</button>
<button class="f" data-t="codex">codex</button><button class="f" data-t="pi">pi</button><button class="f" data-t="__star__">已标记 ★</button><button class="f" data-t="__arch__">已归档</button>
<select id="path"><option value="">全部路径</option></select>
<span class="sep"></span>
<button class="f act" id="reload" title="重新扫描 session 数据">刷新</button>
<button class="f act" id="theme" title="切换深浅主题">◐</button>
</div>
<div class="bar2">
<label>更新</label><input type="date" id="uf"> - <input type="date" id="ut">
<label>创建</label><input type="date" id="cf"> - <input type="date" id="ct">
<label>大小(MB)</label><input type="number" id="smin" min="0" step="0.1" placeholder="最小">
 - <input type="number" id="smax" min="0" step="0.1" placeholder="最大">
<label>状态</label><select id="stf"><option value="">全部</option><option>todo</option>
<option>in progress</option><option>blocked</option><option>done</option></select>
<button class="f" id="clear">清除筛选</button>
</div>
<main><table>
<colgroup><col class="c-star"><col class="c-date"><col class="c-date"><col class="c-tool"><col class="c-model">
<col class="c-name"><col class="c-note"><col class="c-stat"><col><col class="c-path"><col class="c-size"><col class="c-star"></colgroup>
<thead><tr><th data-k="starred">★</th><th data-k="mtime">更新</th><th data-k="birth">创建</th><th data-k="tool">工具</th>
<th data-k="model">模型</th><th data-k="name">名称</th><th data-k="star_note">备注</th><th data-k="status">状态</th><th data-k="first_msg">首条消息</th>
<th data-k="cwd">路径</th><th data-k="size_kb" class="num">大小</th><th title="归档">⊘</th></tr></thead>
<tbody id="tb"></tbody></table>
<div class="foot" id="foot"></div></main>
<div id="toast"></div>
<script type="application/json" id="raw">__DATA__</script>
<script>
const DATA=JSON.parse(document.getElementById('raw').textContent);
const HOME='__HOME__';
const hay=r=>{r._hay=(r.name+' '+r.first_msg+' '+r.cwd+' '+r.star_note+' '+r.model+' '+r.id).toLowerCase()};
DATA.forEach((r,i)=>{r._i=i;hay(r);
  r._p=r.cwd.startsWith(HOME)?'~'+r.cwd.slice(HOME.length):r.cwd;});
const CAP=300;
let tool='',pathSel='',sortK='',sortAsc=false,timer=null;
const q=document.getElementById('q'),tb=document.getElementById('tb'),
      foot=document.getElementById('foot'),toast=document.getElementById('toast'),
      pathEl=document.getElementById('path');
{const cnt={};DATA.forEach(r=>cnt[r.cwd]=(cnt[r.cwd]||0)+1);
 Object.entries(cnt).sort((a,b)=>b[1]-a[1]).forEach(([p,n])=>{
   const o=document.createElement('option');o.value=p;
   o.textContent=`${p.startsWith(HOME)?'~'+p.slice(HOME.length):p} (${n})`;
   pathEl.appendChild(o);});}
pathEl.onchange=()=>{pathSel=pathEl.value;render()};
document.getElementById('stf').onchange=render;
['uf','ut','cf','ct','smin','smax'].forEach(id=>
  document.getElementById(id).addEventListener('input',()=>{clearTimeout(timer);timer=setTimeout(render,120)}));
document.getElementById('clear').onclick=()=>{
  ['uf','ut','cf','ct','smin','smax'].forEach(id=>document.getElementById(id).value='');
  q.value='';pathEl.value='';pathSel='';document.getElementById('stf').value='';
  document.querySelectorAll('button.f[data-t]').forEach(x=>x.classList.remove('on'));
  document.querySelector('button.f[data-t=""]').classList.add('on');tool='';render();};
const fmt=t=>{const d=new Date(t*1000),z=n=>(n+'').padStart(2,'0');
  return z(d.getMonth()+1)+'-'+z(d.getDate())+' '+z(d.getHours())+':'+z(d.getMinutes())};
const esc=s=>(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const cmd=r=>{const m=r.model;
  if(r.tool==='codex')return`codex resume ${r.id}`+(m?` -m ${m}`:'');
  if(r.tool==='pi')return`cd ${r.cwd} && pi --session ${r.id}`+(m?` --model ${m}`:'');
  return`cd ${r.cwd} && claude -r ${r.id}`+(m?` --model ${m}`:'')};
const STATUS=['','todo','in progress','blocked','done'];
const STC={'todo':'var(--fog)','in progress':'#4ea7fc','blocked':'#eb5757','done':'#4cb782'};
const stSel=r=>`<select class="st" style="color:${STC[r.status]||'var(--smoke)'}">`
  +STATUS.map(s=>`<option value="${s}"${s===r.status?' selected':''}>${s||'无'}</option>`).join('')+'</select>';
function pop(msg){toast.textContent=msg;toast.classList.add('show');
  clearTimeout(pop._t);pop._t=setTimeout(()=>toast.classList.remove('show'),1200)}
function render(){
  const kw=q.value.trim().toLowerCase();
  let rows=DATA;
  if(tool==='__arch__')rows=rows.filter(r=>r.archived);
  else{rows=rows.filter(r=>!r.archived);
    if(tool==='__star__')rows=rows.filter(r=>r.starred);
    else if(tool)rows=rows.filter(r=>r.tool===tool);}
  if(pathSel)rows=rows.filter(r=>r.cwd===pathSel);
  const from=id=>{const v=document.getElementById(id).value;
    return v?new Date(v+'T00:00:00').getTime()/1000:null};
  const to=id=>{const v=document.getElementById(id).value;
    return v?new Date(v+'T23:59:59').getTime()/1000:null};
  const uf=from('uf'),ut=to('ut'),cf=from('cf'),ct=to('ct'),
        smin=parseFloat(document.getElementById('smin').value),
        smax=parseFloat(document.getElementById('smax').value);
  if(uf)rows=rows.filter(r=>r.mtime>=uf);
  if(ut)rows=rows.filter(r=>r.mtime<=ut);
  if(cf)rows=rows.filter(r=>r.birth>=cf);
  if(ct)rows=rows.filter(r=>r.birth<=ct);
  if(!isNaN(smin))rows=rows.filter(r=>r.size_kb>=smin*1024);
  if(!isNaN(smax))rows=rows.filter(r=>r.size_kb<=smax*1024);
  const sf=document.getElementById('stf').value;
  if(sf)rows=rows.filter(r=>r.status===sf);
  if(kw)rows=rows.filter(r=>r._hay.includes(kw));
  if(sortK)rows=[...rows].sort((a,b)=>{const x=a[sortK],y=b[sortK];
    return(x<y?-1:x>y?1:0)*(sortAsc?1:-1)});
  else rows=[...rows].sort((a,b)=>b.mtime-a.mtime);
  const total=rows.length;rows=rows.slice(0,CAP);
  if(!total){
    tb.innerHTML=`<tr><td colspan="12"><div class="empty">没有匹配的 session，试试更短的关键词或切换筛选</div></td></tr>`;
    foot.textContent='';syncSortMark();return;}
  tb.innerHTML=rows.map(r=>`<tr class="row${r.starred?' starred':''}${r.archived?' archived':''}" data-i="${r._i}">
   <td class="starcell" title="${r.starred?'取消标记':'标记重要'}">${r.starred?'★':'☆'}</td>
   <td class="dt">${fmt(r.mtime)}</td><td class="dt">${fmt(r.birth)}</td><td class="tool">${r.tool}</td>
   <td class="tool" title="${esc(r.model)}">${esc(r.model)}</td>
   <td class="namecell nm" title="点击改名">${esc(r.name)}</td>
   <td class="notecell" title="点击编辑备注">${esc(r.star_note)}</td>
   <td>${stSel(r)}</td>
   <td class="msg" title="${esc(r.first_msg)}">${esc(r.first_msg)||'(空)'}</td>
   <td class="p" title="${esc(r.cwd)}">${esc(r._p)}</td>
   <td class="num sz">${r.size_kb>=1024?(r.size_kb/1024).toFixed(1)+'M':r.size_kb+'K'}</td>
   <td class="archcell" title="${r.archived?'解除归档':'归档（在"已归档"视图可找回）'}">${r.archived?'↩':'⊘'}</td></tr>`).join('');
  foot.textContent=(total>CAP?`显示前 ${CAP} 行，共 ${total} 个匹配，输入关键词缩小范围`:`${total} 个匹配`)
    +'。点击行复制恢复命令，点 ★ 标记，名称/备注列点击编辑，⊘ 归档';
  syncSortMark();
}
function syncSortMark(){
  document.querySelectorAll('th[data-k]').forEach(h=>{
    h.classList.toggle('s-asc',h.dataset.k===sortK&&sortAsc);
    h.classList.toggle('s-desc',h.dataset.k===sortK&&!sortAsc);});
}
q.addEventListener('input',()=>{clearTimeout(timer);timer=setTimeout(render,120)});
tb.addEventListener('change',async e=>{
  if(!e.target.classList.contains('st'))return;
  const r=DATA[+e.target.closest('tr').dataset.i],status=e.target.value;
  const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,status})});
  if(!resp.ok){pop('保存失败');return}
  r.status=status;pop(status?'状态：'+status:'已清除状态');render();});
tb.addEventListener('click',async e=>{
  if(e.target.tagName==='SELECT')return;
  const tr=e.target.closest('tr.row');if(!tr)return;
  const r=DATA[+tr.dataset.i];
  if(e.target.classList.contains('starcell')){
    const star=!r.starred;
    const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,star})});
    if(!resp.ok){pop('保存失败');return}
    r.starred=star;pop(star?'已标记':'已取消');render();
    return;}
  if(e.target.classList.contains('notecell')){
    const note=prompt('备注',r.star_note||'');
    if(note===null)return;
    const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,note})});
    if(!resp.ok){pop('保存失败');return}
    r.star_note=note;hay(r);pop('已保存');render();
    return;}
  if(e.target.classList.contains('archcell')){
    const archive=!r.archived;
    const resp=await fetch('/star',{method:'POST',body:JSON.stringify({id:r.id,archive})});
    if(!resp.ok){pop('保存失败');return}
    r.archived=archive;pop(archive?'已归档':'已解除归档');render();
    return;}
  if(e.target.classList.contains('namecell')){
    const name=(prompt('名称',r.name||'')||'').trim();
    if(!name||name===r.name)return;
    const resp=await fetch('/rename',{method:'POST',body:JSON.stringify({id:r.id,tool:r.tool,name})});
    if(!resp.ok){pop('改名失败');return}
    r.name=name;hay(r);
    pop(r.tool==='codex'?'已改名（仅本工具可见，codex 上游无处存名）':'已改名');render();
    return;}
  navigator.clipboard.writeText(cmd(r));pop('已复制恢复命令');});
document.getElementById('reload').onclick=()=>{location.href='/?fresh=1'};
document.getElementById('theme').onclick=()=>{
  const t=document.documentElement.dataset.theme==='dark'?'light':'dark';
  document.documentElement.dataset.theme=t;localStorage.theme=t;};
document.querySelectorAll('button.f[data-t]').forEach(b=>b.onclick=()=>{
  document.querySelectorAll('button.f[data-t]').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');tool=b.dataset.t;render();});
let resizing=false;
document.querySelectorAll('th[data-k]').forEach(h=>h.onclick=()=>{
  if(resizing)return;
  const k=h.dataset.k;sortAsc=(sortK===k)?!sortAsc:false;sortK=k;render();});
// 列宽拖拽：改 colgroup 宽度，存 localStorage
const cols=[...document.querySelectorAll('colgroup col')];
try{JSON.parse(localStorage.colw5||'[]').forEach((w,i)=>{if(w&&cols[i])cols[i].style.width=w+'px'})}catch(e){}
document.querySelectorAll('thead th').forEach((h,i)=>{
  if(i>=cols.length-1)return;
  const g=document.createElement('span');g.className='rs';h.appendChild(g);
  g.addEventListener('mousedown',e=>{
    e.preventDefault();e.stopPropagation();resizing=true;g.classList.add('on');
    const x0=e.clientX,w0=cols[i].getBoundingClientRect().width;
    const move=ev=>{cols[i].style.width=Math.max(36,w0+ev.clientX-x0)+'px'};
    const up=()=>{document.removeEventListener('mousemove',move);
      document.removeEventListener('mouseup',up);g.classList.remove('on');
      localStorage.colw5=JSON.stringify(cols.map(c=>parseInt(c.style.width)||null));
      setTimeout(()=>resizing=false,0)};
    document.addEventListener('mousemove',move);document.addEventListener('mouseup',up);});});
render();
</script>
</body></html>"""


# ─── main ────────────────────────────────────

def main():
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    args = sys.argv[1:]
    if not args:
        last = DATA_DIR / "last-active.txt"
        print(last.read_text() if last.exists() else "还没有快照（session-tracker 每 5 分钟生成）")
        return
    if args[0] in ("-h", "--help"):
        print(__doc__)
        return
    if args[0] == "_serve":
        serve()
        return
    n = 20
    if "-n" in args:
        i = args.index("-n")
        n = int(args[i + 1])
        del args[i:i + 2]
    cmd, rest = args[0], args[1:]
    if cmd == "list":
        cmd_list(n, rest[0] if rest else None)
    elif cmd == "find" and rest:
        cmd_find(" ".join(rest), n)
    elif cmd == "star" and rest:
        cmd_star(rest[0], " ".join(rest[1:]))
    elif cmd == "unstar" and rest:
        cmd_unstar(rest[0])
    elif cmd == "stars":
        cmd_stars()
    elif cmd == "dash":
        cmd_dash(rest)
    else:
        print(__doc__)
        sys.exit(1)


if __name__ == "__main__":
    main()
